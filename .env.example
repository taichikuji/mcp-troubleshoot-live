# Filename of the support bundle inside the ./bundles/ directory.
# The container expects the file at /bundles/<this value>.
BUNDLE_PATH=/bundles/bundle.tar.gz

# Port the MCP server listens on (host and container)
PORT=3000

# Address the local Kubernetes API proxy binds to inside the container
PROXY_ADDRESS=localhost:8080

# Uncomment to pin a specific kubectl release
# KUBECTL_VERSION=v1.29.4