# --- Networking ----------------------------------------------------------

# Host port mapped to the container's internal port 3000.
# Change if 3100 conflicts with another service on your machine.
HOST_PORT=3100

# Optional override for the upload base URL shown by prepare_upload.
# Leave UNSET in nearly all cases — the server derives it per-request from
# the client's Host header (honors X-Forwarded-Proto/X-Forwarded-Host behind
# a reverse proxy), so multi-host deployments work with no config:
#
# - Cursor on Mac → MCP on UTM Ubuntu VM : auto-detected from Cursor's request
# - Cursor on Mac → MCP behind nginx     : auto-detected via X-Forwarded-*
# - Cursor on Mac → MCP on Tailscale     : auto-detected from MagicDNS host
#
# Only set this if auto-detection is wrong (e.g. a CDN that strips/rewrites
# Host without setting X-Forwarded-* properly).
# PUBLIC_URL=http://my-mcp.example.com

# --- Bundle source -------------------------------------------------------

# Directory the AI scans for already-on-server bundles via list_bundles.
# Mount your host bundle folder at this path in docker-compose.yml.
# BUNDLES_DIR=/bundles

# --- Upload limits + cleanup --------------------------------------------

# Max upload size in bytes. Default 5 GB. Increase if your bundles are bigger.
# MAX_UPLOAD_BYTES=5368709120

# How long an idle uploaded bundle survives before the reaper deletes it
# (milliseconds). Default 6 h. The currently-loaded bundle is always kept.
# UPLOAD_TTL_MS=21600000

# How often the reaper runs (milliseconds). Default 30 min.
# UPLOAD_SWEEP_INTERVAL_MS=1800000

# Where uploads land inside the container. Stays out of /bundles so it never
# pollutes your host-mounted folder. Wiped on container restart.
# UPLOAD_DIR=/tmp/troubleshoot-mcp-uploads

# --- Extraction limits --------------------------------------------------

# Temporary directory for the active extracted bundle. Wiped on startup.
# BUNDLE_CACHE_DIR=/tmp/troubleshoot-mcp-cache

# Archive-bomb limits. Defaults: 20 GB expanded data and 500,000 files.
# MAX_EXTRACTED_BYTES=21474836480
# MAX_ARCHIVE_FILES=500000
