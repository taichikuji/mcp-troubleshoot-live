# Optional: bundle to auto-load on container startup.
# Drop your .tar.gz support bundles into ./bundles/ on the host so they show
# up at /bundles/<filename> inside the container.
# Leave UNSET to start with no bundle loaded — the AI can then call the
# list_bundles and start_bundle tools to pick one (and switch between bundles
# without restarting the container).
# BUNDLE_PATH=/bundles/bundle.tar.gz

# Directory the AI scans for available bundles via list_bundles.
# BUNDLES_DIR=/bundles

# Host port that maps to the container's internal port 3000.
# Change if 3100 conflicts with another service on your machine (e.g. Gitea uses 3000).
HOST_PORT=3100

# Address the local Kubernetes API proxy binds to inside the container.
PROXY_ADDRESS=localhost:8080

# Where troubleshoot-live writes the kubeconfig the MCP server reads.
# Defaults to /tmp/kubeconfig; override only if you mount it somewhere.
# KUBECONFIG_PATH=/tmp/kubeconfig

# Per-call timeout for kubectl invocations (milliseconds, default 30000).
# KUBECTL_TIMEOUT_MS=30000

# How long start_bundle/auto-start waits for the cluster API to come up
# (milliseconds, default 120000). Increase for cold starts that need to
# download envtest binaries.
# CLUSTER_READY_TIMEOUT_MS=120000

# Pin a specific kubectl release at image build time.
# KUBECTL_VERSION=v1.29.4
